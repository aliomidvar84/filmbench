# FilmBench Web — Next.js standalone
FROM node:20-alpine AS deps
WORKDIR /app
COPY package.json package-lock.json ./
COPY apps/web/package.json apps/web/
COPY packages/shared/package.json packages/shared/
RUN npm ci

FROM node:20-alpine AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY . .
ARG NEXT_PUBLIC_API_URL=http://127.0.0.1:4000
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
RUN npm run build -w @filmbench/web

FROM node:20-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production
ENV HOSTNAME=0.0.0.0
ENV PORT=3000

RUN addgroup -S filmbench && adduser -S filmbench -G filmbench

COPY --from=builder /app/apps/web/public ./apps/web/public
COPY --from=builder --chown=filmbench:filmbench /app/apps/web/.next/standalone ./
COPY --from=builder --chown=filmbench:filmbench /app/apps/web/.next/static ./apps/web/.next/static

USER filmbench
EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=5s --start-period=30s --retries=3 \
  CMD wget -q -O - http://127.0.0.1:3000/ || exit 1

CMD ["node", "apps/web/server.js"]
