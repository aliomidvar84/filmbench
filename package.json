{
  "name": "filmbench",
  "version": "0.1.0",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "npm run dev -w @filmbench/web",
    "dev:api": "npm run dev -w @filmbench/api",
    "dev:local": "powershell -ExecutionPolicy Bypass -File scripts/dev-local.ps1",
    "build": "npm run build -w @filmbench/api && npm run build -w @filmbench/web",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "db:migrate": "npm run migrate -w @filmbench/db",
    "db:seed-insights": "npm --prefix . exec -- tsx packages/db/src/seed-insights.ts",
    "analytics:sync": "npm --prefix . exec -- tsx scripts/analytics-sync.ts",
    "analytics:scheduler": "npm --prefix . exec -- tsx scripts/analytics-scheduler.ts",
    "analytics:sync:now": "npm --prefix . exec -- tsx scripts/analytics-scheduler.ts -- --now",
    "test:analytics:e2e": "npm run test:e2e -w @filmbench/analytics",
    "docker:prod:up": "docker compose -f docker-compose.prod.yml up -d --build",
    "docker:prod:migrate": "docker compose -f docker-compose.prod.yml run --rm migrate",
    "docker:prod:down": "docker compose -f docker-compose.prod.yml down"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "eslint": "^9.39.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.0",
    "vitest": "^3.2.4"
  }
}
